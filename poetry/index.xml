<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>رِواق الشِعر on بلتاجي الرمحي</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/</link><description>Recent content in رِواق الشِعر on بلتاجي الرمحي</description><generator>Hugo</generator><language>ar</language><lastBuildDate>Fri, 13 Mar 2026 00:00:00 +0000</lastBuildDate><atom:link href="https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/index.xml" rel="self" type="application/rss+xml"/><item><title>صِـيدُ الحَقِيقة</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%B1%D8%A7%D9%81%D8%A7%D9%84-%D8%B9%D9%8A%D9%86%D9%8A/</link><pubDate>Fri, 13 Mar 2026 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%B1%D8%A7%D9%81%D8%A7%D9%84-%D8%B9%D9%8A%D9%86%D9%8A/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الشطر الأول&lt;/th&gt;
 &lt;th style="text-align: left"&gt;الشطر الثاني&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;رافال عينى إن ما لقلوب اتعيّر&lt;/td&gt;
 &lt;td style="text-align: left"&gt;وتهلب جواجى اكبودهم وانياهم&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;انبيعها بلاش ولا ف يوم انشيّر&lt;/td&gt;
 &lt;td style="text-align: left"&gt;علي صيد ينقالي بـعـدها واهم&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>خَيَالُ أَفْلَاطُون</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%A7%D9%81%D9%84%D8%A7%D8%B7%D9%88%D9%86-/</link><pubDate>Thu, 12 Mar 2026 23:45:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%A7%D9%81%D9%84%D8%A7%D8%B7%D9%88%D9%86-/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الشطر الأول&lt;/th&gt;
 &lt;th style="text-align: left"&gt;الشطر الثاني&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;طوااها بخياله افلاطون&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مذابح ثلاثين راعي&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وزرع بدمّها اغصان زيتون&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ومات ما نظر غصن واعي&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>آيَةُ مِن الشِّعْرِ</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%B1%D8%B3%D9%88%D9%84-%D8%A7%D9%84%D8%B4%D8%B9%D8%B1/</link><pubDate>Thu, 12 Mar 2026 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%B1%D8%B3%D9%88%D9%84-%D8%A7%D9%84%D8%B4%D8%B9%D8%B1/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الشطر الأول&lt;/th&gt;
 &lt;th style="text-align: left"&gt;الشطر الثاني&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;نا هو رسول الشعر كان محمّد&lt;/td&gt;
 &lt;td style="text-align: left"&gt;خاتم رُسل ربي عليِ هالارض&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولاني القول لقوّته متعمّد&lt;/td&gt;
 &lt;td style="text-align: left"&gt;بنات فكر فارضته عليا فرض&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;لو جايني صالح وهو متثمّد&lt;/td&gt;
 &lt;td style="text-align: left"&gt;خابت ثمود وما قبلت العرض&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;إلا بآية شعرٍ سرمديٍ سرَمّد&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ما جابها عقّال عيت القرض&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا دُهاة إشبيليه مُتغَمّد&lt;/td&gt;
 &lt;td style="text-align: left"&gt;في جزالة وحي عصر انقرض&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولا جيتكم في شطر بوه ملمّد&lt;/td&gt;
 &lt;td style="text-align: left"&gt;يا ملمّدين الدم من يعترض&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;إن ما تعرفو راه فكركم متجمد&lt;/td&gt;
 &lt;td style="text-align: left"&gt;خالي تماما من سمو الغرض&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;لو صوتكم في حضرتي متخمّد&lt;/td&gt;
 &lt;td style="text-align: left"&gt;هذا طبيعي مو مجرد عرض&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;نا هو اللي نجرح وفيه نضمّد&lt;/td&gt;
 &lt;td style="text-align: left"&gt;سلاماً على حرفي اللامُقترض&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>سمح الكلام</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%A7%D9%84%D9%85%D8%A7%D8%B3-%D8%A7%D9%84%D9%85%D9%87%D9%85%D9%84/</link><pubDate>Thu, 12 Mar 2026 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%A7%D9%84%D9%85%D8%A7%D8%B3-%D8%A7%D9%84%D9%85%D9%87%D9%85%D9%84/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الصدر&lt;/th&gt;
 &lt;th style="text-align: left"&gt;العجز&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;والله الكلام لو علّا ملل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ما الاعمال المولى حطّها&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وسمح الكلام ما دل وكمل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;سهمه مدّ لو طال المدا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;مراده سمح داوا لو هطلّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ودوم السر صدرا كامرا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;سلم م المكر واعكاس العلل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;عدو الكرى والاسر والمحوا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;لاح الود مسلول طالل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;طواه مطر مطاول طما&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;كاسه ملك راسه مكلل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ماسح كِل ما دار الصدا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وصام الهوا الدهر كامل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;هول السَّحَر كله رعـا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولم العلم صال حامل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;سهم العمر صار مرسا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;مدحه الهمّ حلّاه حوّل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;عطره مهر طواها الوطا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولو راد الهلال هوّل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ما هل لا حل حلّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وسال الهلال هل هل ؟&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ولو هل الهلال كملّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;طال هود دعا عاد ما ملّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مو مُهِِم وصّل الدعوا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;المُهِم الراى عدّل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;عمل صح وما صح لولا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولا طاح الا ووصل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;اعلومه المُرسل لها&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وكاد كِل حسّاد هامل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;سود المدامع ردمها&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;كلام رمح لا صاح صاهل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ولد ارماح احرار الدما&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;دردر اكرومر وململ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;عدو دار الاهرام كدّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;صده حلم ملوك الدول&lt;/td&gt;
 &lt;td style="text-align: left"&gt;سرا السر كسواه الرحا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;حمد رد لمصر حامل&lt;/td&gt;
 &lt;td style="text-align: left"&gt;حصاد عمر ألماس مالطا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>حَلِيبُ الرَّضِيف</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%AE%D8%B7%D8%A7%D8%B7%D9%8A%D9%81/</link><pubDate>Sat, 25 May 2024 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%AE%D8%B7%D8%A7%D8%B7%D9%8A%D9%81/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الشطر الأول&lt;/th&gt;
 &lt;th style="text-align: left"&gt;الشطر الثاني&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;خـطرها حليب الرضيف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;اطـيّبه حـجارة المـسارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وعـلي صـهدها والوجيف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مـا تـنتظر شكر الشوارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولـبـنادم ان فـاته الـزيف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;كـمـا اطـياح اذنـاب الـعقارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;والـلى اتـخبرك به مواقيف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;اقـحني حليب قُـود شـارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;نـين نـاضحه م الغضاريف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;اعـزومـه اتـبـرّك تـجـارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;امـوسم طـويل كـي طـيف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;عـلي يـمين م الـفخذ صـارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يـقـرا لـعيون الـلواصيف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;الـلـى اقـريّبه م الـلى اتـقارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;قـطاوي اسـلم م الـتخاريف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;فـيـه جـوف يـاسع الـغوارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;بـ آى ار تـغزي التجاويف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مـا تـجـيب مـيراج خـارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;امـحـرم عـلـيه الـولـيف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مـن اقـران مـدح الـمغارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وطـبع البشر مج الحصيف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;وتـرغـب الـبـاب الـمـوارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;والـلى مـا فهم فيت تخطيف&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مـوش ذنب عـقلى الـطارب&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>زواجل طيري</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/watan/</link><pubDate>Sat, 25 May 2024 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/watan/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الشطر الأول&lt;/th&gt;
 &lt;th style="text-align: left"&gt;الشطر الثاني&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;بلا مودِّنة عارف زواجل طيري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;والحمد لله اللى بسط جرتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولا انظري ناسيهن اصوات هديري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;فاوقات الانظار اللى انذهب شيرتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا صاحبي السيّه انه تفكيري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ما جابها البيعة وسهرايتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وراي ؟ لاااا لقيتك فيّ نافخ كيري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ضلن جواجيك هذي حجتّا ؟؟&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;تربح ولا لكيفك ينوض طفيري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ولا تصيم عيني عن اللى ولاتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;بيك وبلاك وبيّ نا وبغيري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;تطّايب اجروحي تنقتل غصتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;امطارهن ارعودي مكفيات شعيري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;علي قلها ما اسمح طعم غلتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يحاذر خبيري من ادروب خبيري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;بعيون ما تلاصيف البشر غرتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولا راس مال إلا امفيت ضميري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;وروح تخشى يوم تلظايتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;رايمه المعاني اللافيه لغويري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;اللى سيوف سافيها صلت غطتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولا ب هدهد اسليمان فى تفسيري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;جبتا نبا بلقيس واحكايتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ان مو جبح عقلي مرمّزه تشفيري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;فى صمتّا تبليغ ل كليمتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;جايني كما اركيّب نوا تدميري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;قليده امحرم نطق رجّابتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;لا انباع لا لدينار لا للميري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ولا غرّ به تصفيق لشرايتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;قصيرة اقيون وختمها تقديري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;سلّم اعيوني هي اللى ربتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;بنات عقل حاضيهن دفا كشميري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ما اجرود ((فبراير)) اللى كستّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولو الشعر ترجمهن لغاوي بيري&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ما رُمت قافيته ولا انغمتّا&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>سِيمَةُ الأَخْيَار</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/sample-poem/</link><pubDate>Sat, 25 May 2024 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/sample-poem/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الشطر الأول&lt;/th&gt;
 &lt;th style="text-align: left"&gt;الشطر الثاني&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا نجع ما هوّنت راي لشايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ويا نجع ما كبّرت يوم احوار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;تبويعتك لهلة كل لافي غايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;تشهد عليها كل رمة دار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا نجع تذبح م اللذيذ الطايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;يا نجع لا ما حذاك جايع جار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا نجع عن فعل الرديه تايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;يا نجع بسماح الفعايل بار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا نجع لمة هلك فيك اتهايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;في كل ذيل ايريد فيك دمار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا نجع لا كشّرت قول كتايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;عالنه احروب وقتل واستنفار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا نجع تهلب في كلام الخايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;يا نجع لا ما حاد بيك مسار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا نجع لا ام التوم لا ام جنايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;تصبح غفود ولا خلوج عشار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا نجع جود الجود منك جايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;سيمته علي مر الازمان اخيار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا نجع خلّك من زفيّ العايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;القايل البوم انه سليم مطار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;مشايخ ابطون وف العقول ذهايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;يحاحو لقطا قالو طيور حرار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وياما احملنا م الزمان غرايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;برم وقتنا والحبل ع الجرار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا نجع ديما كيف لون الرايب&lt;/td&gt;
 &lt;td style="text-align: left"&gt;جهيمك اتقول انه عقاب اغرار&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>غَرَابِيبُ الضِّيّ</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%BA%D8%B1%D8%A7%D8%A8%D9%8A%D8%A8%D9%87%D8%A7-/</link><pubDate>Sat, 25 May 2024 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%BA%D8%B1%D8%A7%D8%A8%D9%8A%D8%A8%D9%87%D8%A7-/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الشطر الأول&lt;/th&gt;
 &lt;th style="text-align: left"&gt;الشطر الثاني&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;غرابيبها حاين سجايا ضيّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ضميره محل إعراب كلمة لنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;شواطيه غرّن به اتبّع غيّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مبادي اتكسي روحها بكفنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;عليه عالنين اسيوف عيت الكيّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;امغير سيفهم حدّه يريد مسنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;كيفه الدوج لهن صليل رديّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;بعَد نوضته ف الناس قالو غَنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;واسلمت وعمّر اعقيلك بَيّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;وواهمين جد البَيّ كاين منّ ؟&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وما اتقول لي لنّا افعال الحيّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ياما ولد سَلول وَدّ وحَنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وهو فيه يتّقه بقصر الديّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ميّس انفوس اتموت كان صفَنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وراهو جمال الشيّ مو ف الشيّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;امغير لعقول الذاهبه ما بنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;قولو لهم بو الزغل كان وفيّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;وقولو لغرناطه آمال حسنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وقولو لهم يرحم الله عليّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ما هو علي طهران لا سَاسنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;خوذو لغلاف ونا اكتابي ليّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ما انسلّمه طايع ولا بثمنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وهضا لاو بشرع ولا كلام نبيّ&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ولا هو بجن إن كان قالو جنّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>غَياهِب دَوج</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%BA%D9%8A%D8%A7%D9%87%D8%A8-%D8%A7%D9%84%D8%AF%D9%88%D8%AC/</link><pubDate>Sat, 25 May 2024 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%BA%D9%8A%D8%A7%D9%87%D8%A8-%D8%A7%D9%84%D8%AF%D9%88%D8%AC/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الشطر الأول&lt;/th&gt;
 &lt;th style="text-align: left"&gt;الشطر الثاني&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;خاطى غياهب الدوج&lt;/td&gt;
 &lt;td style="text-align: left"&gt;وانجى بعقلك وطرّف&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ماريت له اثمره ومنتوج&lt;/td&gt;
 &lt;td style="text-align: left"&gt;فيت كل من قالوا امخرّف&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>مواير سراب</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D9%85%D9%88%D8%A7%D9%8A%D8%B1-%D8%B3%D8%B1%D8%A7%D8%A8/</link><pubDate>Sat, 25 May 2024 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D9%85%D9%88%D8%A7%D9%8A%D8%B1-%D8%B3%D8%B1%D8%A7%D8%A8/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الشطر الأول&lt;/th&gt;
 &lt;th style="text-align: left"&gt;الشطر الثاني&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;خـطاطيف صمته سارقات كلامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;تـاهن بـه عروق الظل وسط ادروبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;مـا اقـربت بير الحِن يوم ابهامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;إلا اغـتـالها اربـعـين لـيل بـشوبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;تنوّض عصاته في اطيور احلامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;تـهيّب الـريش الخضر قبل اخضوبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;جـافل هوى نـفسه يقل اسوامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;فـى رفـق تـافه شـيرته مـذهوبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;دواويـه نـص بـذارها الـندامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ثـامن سـنـابـلها ادردر صـوبـه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يـفاخر بـسوه دوج هـدّ احـكامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ديـموم فـكر غـربي قـربته مذبوبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ومواير السراب يغرّ ف الصوّامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;نـين يـشربو رمـضه بـعيدة جـوبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ويـزّايد غـلا البعيد وقت اخصامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;كـي الـضي لونه ذروته ف غروبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وديـما الاوقـات اتـباعد الـفهّامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;بـيش تـختلي بـارمام راقـي دوبـه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وهضاك بغداد اتغزيّ في صدّامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;يـوسـفه مـجـففن امـزن يـعقوبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;بـتفاسير غلباتّن اضغاث احلامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;تـنابت سـهاريهن ف وطـن اعـيوبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;طـريقه هَـروج وحافيات اقدامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;سـقى دمـهّن جـرحه بنهر انضوبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;لا صـاف عقله من نزيف اقلامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ولا ربـيـع حـاياهن زخـارف ثـوبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;حـال غايته يجمع اطلال احطامه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ويـكسيهن لـحم وتـرد روح اقـلوبه&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>نَادِرُ الفَصّ</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%B1%D9%8A%D8%AA%D9%87-%D9%88%D8%AA%D9%88-%D8%A7%D8%AA%D8%AD%D9%82%D9%87%D8%A7/</link><pubDate>Sat, 25 May 2024 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%B1%D9%8A%D8%AA%D9%87-%D9%88%D8%AA%D9%88-%D8%A7%D8%AA%D8%AD%D9%82%D9%87%D8%A7/</guid><description>&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الشطر الأول&lt;/th&gt;
 &lt;th style="text-align: left"&gt;الشطر الثاني&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;رِيــــتــه وتـــو اتــحــقها قــانــصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;وتقول كــنــت انــريــدها إلا لــوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;مــا جــابها اخريفيش صاعب نصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;يــنــوّض الــحرشا اتــقول هــيا تــوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;مــواريث جــده وهو عليها موصّى&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ولا خــير فــيه ان عاف مــا سمّو&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وتــابــع ادروبـــه كــلها مــاصصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;هــضاك كــان هــو وهــضا هو هوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;مـــا قــالها مــن قــبل مــا شــخصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;كــي عــيت ( حــيها ) لمّدو وحشوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وراك تــعرفه قصدي وهذيك القصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ومــن هو اللي جفّل ومن ( شاكوّ )&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وزاد تــعرفه مــن هــو اللي نغصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;زمــرة اكــلاب القاف عيت ( الشوّ)&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يــجو كــلمتين ويــغلبو ف الــرصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مــاريــت فــيــهن م الــمــواير قــوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولــو الاصــمعي هضاك مستخلصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;خــبــرة تــجــارب مـــن زمــانه أوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;عــــقــل رــــبي خــالــقه يــقــلصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;فـــي شــطر شــعري او بــما أبــدَوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;انـــه يــمتلك اعــين فــقط تــمتصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مـــن ســمح مــا قــالو ومــا خــطَوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;انــا أؤكــد لــك بــانك لــو اتمحصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;ســاتــقول لـــي بــالــك بــها جــلَّوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وانـــه شــبيه الــماس نــادر فصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;خــافي عــلي دوج الــعرب والضوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ومـــا تــرجمته بــلتاجي امــخلصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مـــن كـــل شــائبة تــحتوي الــسوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;ولــو كــان مــا تعرف انه مخمصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;وانـــه قــايــل ووصــلتم ومــا ردَوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;الــرمحي ومــا يرجى اللي يرخصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;شــــعــارهــا ونــقــادهــا والــــجــوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;وحرصا على التوضيح ماهي حصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;فــي لــغة ضــاد الــلي لــها احــتمَوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;نــردو لــموضوعي الــلي حــمصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;اكــبــودهم بــما راعــو ومــا ابــتلَوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;بــارماق دامــي ف الوغى مختصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;عــارفــينها جــتــهم بــهــا انـــرزوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;واضــع بــها دســتورها امــخصصّه&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مـــا يــرومــها الا مَــن لــها ادّعــوّ&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item><item><title>وِسَامُ القَيْصَر (مِنْ أَجْدَابِيَا)</title><link>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%AF%D9%8A%D9%88%D8%A7%D9%86-%D8%B5%D8%A7%D8%AD%D8%A8-%D9%88%D8%B2%D9%86-%D9%88%D8%A7%D9%81%D9%8A/</link><pubDate>Sat, 25 May 2024 00:00:00 +0000</pubDate><guid>https://beltagy-mohamed.github.io/Beltagy-poetry-website/poetry/%D8%AF%D9%8A%D9%88%D8%A7%D9%86-%D8%B5%D8%A7%D8%AD%D8%A8-%D9%88%D8%B2%D9%86-%D9%88%D8%A7%D9%81%D9%8A/</guid><description>&lt;p&gt;&lt;strong&gt;بلحاج علي التمَّامي&lt;/strong&gt;&lt;/p&gt;
&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th style="text-align: left"&gt;الصدر&lt;/th&gt;
 &lt;th style="text-align: left"&gt;العجز&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;يا ديوان صاحب وزن وافي&lt;/td&gt;
 &lt;td style="text-align: left"&gt;قول ونظم متميز وشافي&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;صــاحـب وزن نــاجـي&lt;/td&gt;
 &lt;td style="text-align: left"&gt;مـالـهـفو والـتـكـسير يـــا بـلـتـاجى&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;نـظمك نـظم فـالزينه ايـدااجي&lt;/td&gt;
 &lt;td style="text-align: left"&gt;وصـرفك صـرف متنوع وعافي&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;صـاحب فـكر مـتميز امحاجي&lt;/td&gt;
 &lt;td style="text-align: left"&gt;هل العقول في نظمك خُرافي&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;كـلمة حـق مـن قـيصر ايـناجي&lt;/td&gt;
 &lt;td style="text-align: left"&gt;نـظم الـقول بـاقواله ايكافي&lt;/td&gt;
 &lt;/tr&gt;
 &lt;tr&gt;
 &lt;td style="text-align: left"&gt;هاك اهداء من بُعد الافجاجي&lt;/td&gt;
 &lt;td style="text-align: left"&gt;من عااصمة نظم الشعر لافي&lt;/td&gt;
 &lt;/tr&gt;
 &lt;/tbody&gt;
&lt;/table&gt;</description></item></channel></rss>